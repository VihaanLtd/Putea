# Akahu API credentials — https://my.akahu.io/
AKAHU_APP_TOKEN=your_app_token_here
AKAHU_USER_TOKEN=your_user_token_here

# Anthropic Claude API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Clerk authentication — https://dashboard.clerk.com/
# Publishable key (frontend, safe to expose)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
# Secret key (backend only, never expose)
CLERK_SECRET_KEY=sk_test_your_key_here

# Optional: API port (default 3001)
PORT=3001

# Frontend email allowlist (comma-separated). Optional — the backend allowlist
# in api/personal.js is the source of truth. Leave empty to skip the frontend
# check and rely solely on the backend.
VITE_ALLOWED_EMAILS=